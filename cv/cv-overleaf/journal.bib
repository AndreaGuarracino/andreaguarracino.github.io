@article {Bolognini2026.02.05.704023,
	author = {Bolognini*, Davide and \textbf{Andrea Guarracino}* and Paleni, Chiara and Dudley, Thomas Sumner and Iacoviello, Licia and Raveane, Alessandro and Sudmant, Peter H and Garrison, Erik and Soranzo, Nicole},
	title = {Population-scalable genotyping from low-coverage sequencing data using pangenome graphs},
	elocation-id = {2026.02.05.704023},
	year = {Submitted},
	doi = {10.64898/2026.02.05.704023},
	publisher = {Cold Spring Harbor Laboratory},
	abstract = {Pangenome-based genotyping of structurally complex loci remains challenging at low sequencing depths, particularly when samples are of low quality, such as in ancient DNA. We present COSIGT (COsine SImilarity-based GenoTyper), a method that infers structural genotypes by matching short-read coverage patterns to pangenome haplotypes using cosine similarity. COSIGT maintains robust accuracy at low coverage (1-2X), outperforming existing methods where depth-sensitive approaches degrade. We demonstrate scalability to thousands of modern and ancient genomes, enabling population-scale analyses of complex variation from low-coverage data.Competing Interest StatementThe authors have declared no competing interest.NSF PPoSS Award, 118709NIH, R01HG013618, U01HG013760, U01DA057530, U41HG010972, R01HG013017},
	URL = {https://www.biorxiv.org/content/early/2026/02/06/2026.02.05.704023},
	eprint = {https://www.biorxiv.org/content/early/2026/02/06/2026.02.05.704023.full.pdf},
	journal = {bioRxiv},
    note = {\textit{\textbf{Contribution: Software development, evaluations, manuscript writing.}}}
}

