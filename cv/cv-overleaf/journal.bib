@article {Darnell2024.10.16.618663,
	author = {Darnell, Shelby Solomon and Overall, Rupert W. and \textbf{Andrea Guarracino} and Colonna, Vincenza and Villani, Flavia and Garrison, Erik and Isaac, Arun and Muli, Priscilla and Muriithi, Frederick Muriuki and Kabui, Alexander and Kilungi, Munyoki Bonface and Lisso, Felix and Kibet, Adrian and Muhia, Brian and Nijveen, Harm and de Ligt, Joep and Yousefi, Siamak and Ashbrook, David G and Huang, Pengzhi and Suh, G. Edward and Umar, Muhammad and Batten, Christopher and Chen, Hao and Sen, Saunak and Williams, Robert W. and Prins, Jacobus Pjotr},
	title = {Creating a biomedical knowledge base by addressing GPT inaccurate responses and benchmarking context},
	elocation-id = {2024.10.16.618663},
	year = {2025},
	doi = {10.12688/openresafrica.15854.1},
	publisher = {Cold Spring Harbor Laboratory},
	abstract = {We created GNQA, a generative pre-trained transformer (GPT) knowledge base driven by a performant retrieval augmented generation (RAG) with a focus on aging, dementia, Alzheimer{\textquoteright}s and diabetes. We uploaded a corpus of three thousand peer reviewed publications on these topics into the RAG. To address concerns about inaccurate responses and GPT {\textquoteright}hallucinations{\textquoteright}, we implemented a context provenance tracking mechanism that enables researchers to validate responses against the original material and to get references to the original papers. To assess the effectiveness of contextual information we collected evaluations and feedback from both domain expert users and {\textquoteright}citizen scientists{\textquoteright} on the relevance of GPT responses. A key innovation of our study is automated evaluation by way of a RAG assessment system (RAGAS). RAGAS combines human expert assessment with AI-driven evaluation to measure the effectiveness of RAG systems. When evaluating the responses to their questions, human respondents give a "thumbs-up" 76\% of the time. Meanwhile, RAGAS scores 90\% on answer relevance on questions posed by experts. And when GPT-generates questions, RAGAS scores 74\% on answer relevance. With RAGAS we created a benchmark that can be used to continuously assess the performance of our knowledge base. Full GNQA functionality is embedded in the free GeneNetwork.org web service, an open-source system containing over 25 years of experimental data on model organisms and human. The code developed for this study is published under a free and open-source software license at https://git.genenetwork.org/gn-ai/tree/README.md.Competing Interest StatementA. Kibet and B. Muhia are founders of FahamuAI, a company that provided a RAG service and API used in this study. The remaining authors declare no competing interests.},
	URL = {https://www.biorxiv.org/content/early/2024/10/18/2024.10.16.618663},
	eprint = {https://www.biorxiv.org/content/early/2024/10/18/2024.10.16.618663.full.pdf},
	journal = {Open Research Africa},
        note = {\textit{\textbf{Contribution: Testing, paper editing.}}}
}

